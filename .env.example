# Token du bot Discord. Ne le publie et ne le colle jamais dans un message.
DISCORD_TOKEN=remplace_par_le_token_dans_render

# Activation et ciblage strict du service Anime News.
ANIME_NEWS_ENABLED=true
ANIME_NEWS_GUILD_ID=1507001707622563890
ANIME_NEWS_EXPECTED_GUILD_NAME=AdoGyaru

# Facultatif après la première création automatique.
# ANIME_NEWS_CHANNEL_ID=identifiant_du_salon_anime_news
# ANIME_NEWS_CATEGORY_ID=identifiant_de_la_categorie_information

# Valeurs recommandées : un contrôle toutes les 90 secondes, news de moins de 36 h.
ANIME_NEWS_POLL_INTERVAL_MS=90000
ANIME_NEWS_MAX_ITEM_AGE_HOURS=36
